---
import '../styles/global.css';

const marchas = [
  { num: "01", nombre: "Marcha 1", orden: "Cornetas A (x2) -> Pífanos + Lira A (x2) -> Pífanos + Lira B (x2)", videoId: "P7joLvEg4vg", videoCorneta: "QUWLudCrrR8", midiPifano: "/midi/pifano/marcha-1.mid", midiCorneta: "/midi/corneta/marcha-1.mid", midiCaja: "/midi/caja/marcha-1.mid" },
  { num: "02", nombre: "Marcha 2 de aproximación", orden: "Esta marcha va sin corneta/pífano/lira", videoId: "WKwEWhg30Vk", videoCorneta: null, midiPifano: "/midi/pifano/marcha-2.mid", midiCorneta: "/midi/corneta/marcha-2.mid", midiCaja: "/midi/caja/marcha-2.mid" },
  { num: "03", nombre: "Marcha 3", orden: "Cornetas (x2) -> Pífanos + Lira Parte (x2)", videoId: "IQ2SyL-HV_c", videoCorneta: "4RmbCJjMQNA", midiPifano: "/midi/pifano/marcha-3.mid", midiCorneta: "/midi/corneta/marcha-3.mid", midiCaja: "/midi/caja/marcha-3.mid" },
  { num: "04", nombre: "Marcha 5", orden: "Cajas (x1) -> Cornetas A (x2) y B (x1) -> Pífanos + Lira A (x2) y B (x1)", videoId: "uoFiYoaTHT8", videoCorneta: "bIe4MDJMpkU", midiPifano: "/midi/pifano/marcha-4.mid", midiCorneta: "/midi/corneta/marcha-4.mid", midiCaja: "/midi/caja/marcha-4.mid" },
  { num: "05", nombre: "Marcha Jinete", orden: "Cornetas -> Pifanos + Lira", videoId: "OYDRJ_p80T0", videoCorneta: "JOu802LzRj4", midiPifano: "/midi/pifano/marcha-5.mid", midiCorneta: "/midi/corneta/marcha-5.mid", midiCaja: "/midi/caja/marcha-5.mid" },
  { num: "06", nombre: "Marcha Honores", orden: "Cornetas -> Pífanos + Lira", videoId: "kfGbA0GJWN4", videoCorneta: null, midiPifano: "/midi/pifano/marcha-6.mid", midiCorneta: "/midi/corneta/marcha-6.mid", midiCaja: "/midi/caja/marcha-6.mid" },
  { num: "07", nombre: "Traspaso", orden: "Va con Lira", videoId: "1y0CG1KLt2E", videoCorneta: null, midiPifano: "/midi/pifano/marcha-7.mid", midiCorneta: "/midi/corneta/marcha-7.mid", midiCaja: "/midi/caja/marcha-7.mid" },
  { num: "08", nombre: "Marcha de Parada + Traspaso", orden: "Se toca dos veces lo que se tocaba antes del traspaso", videoId: "Q0TF0_GfvZA", videoCorneta: null, midiPifano: "/midi/pifano/marcha-8.mid", midiCorneta: "/midi/corneta/marcha-8.mid", midiCaja: "/midi/caja/marcha-8.mid" },
  { num: "09", nombre: "Himno del liceo", orden: "Aún se está armando", videoId: "NizMVmXtlxg", videoCorneta: "jnXv1Y9qlVM", midiPifano: "/midi/pifano/marcha-9.mid", midiCorneta: "/midi/corneta/marcha-9.mid", midiCaja: "/midi/caja/marcha-9.mid" }
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />  
    <title>Banda Escolar Liceo San José del Carmen - Material de Ensayo</title>
    <meta property="og:title" content="Banda Escolar Liceo San José del Carmen" />
<meta property="og:description" content="Material de ensayo, partituras y marchas para los integrantes de la banda." />
<meta property="og:image" content="https://bandahuique.cl/img/portada-social.png" />
<meta property="og:url" content="https://bandahuique.cl" />
<meta property="og:type" content="website" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://bandahuique.cl/img/portada-social.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
	<script src="https://cdn.jsdelivr.net/combine/npm/tone@14.7.58,npm/@magenta/music@1.23.1/es6/core.js,npm/focus-visible@5,npm/html-midi-player@1.5.0"></script>
  </head>

  <body class="bg-slate-900 text-slate-200 min-h-screen" style="font-family: 'Source Sans 3', sans-serif;">
    <div id="login-password" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/80 backdrop-blur-xl">
  <div class="bg-slate-900 border border-slate-700 p-8 rounded-xl text-center shadow-2xl">
    <h2 class="text-slate-200 font-bold mb-4">Acceso Restringido</h2>
    <input type="password" id="input-password" placeholder="Contraseña..." class="bg-slate-800 text-white px-4 py-2 rounded mb-4 w-full border border-slate-600 outline-none focus:border-yellow-600">
    <button id="btn-acceder" class="w-full bg-yellow-600 hover:bg-yellow-500 text-black font-bold py-2 rounded transition-all">INGRESAR</button>
  </div>
</div>
    <header class="pt-12 pb-8 px-4 text-center">
      <div class="flex justify-center mb-4">
        <img 
  src="/img/logo-banda.svg" 
  alt="Logo de la banda" 
  width="60" 
  height="60" 
  class="drop-shadow-[0_0_10px_rgba(202,138,4,0.5)] object-contain" 
/>
      </div>
      <p class="text-yellow-600/80 uppercase tracking-[0.2em] text-sm font-bold mb-2">Liceo San José del Carmen</p>
      <h1 class="text-4xl md:text-5xl text-yellow-500 mb-6 drop-shadow-md" style="font-family: 'Playfair Display', serif;">
        Banda Escolar<br/>Material de Ensayo
      </h1>
      <div class="flex items-center justify-center gap-4 opacity-50">
        <div class="h-px bg-yellow-500 w-16"></div>
        <div class="w-2 h-2 rotate-45 bg-yellow-500"></div>
        <div class="h-px bg-yellow-500 w-16"></div>
      </div>
    </header>

    <nav class="bg-slate-950 border-y border-yellow-600/30 sticky top-0 z-10 shadow-lg">
      <div class="max-w-4xl mx-auto flex flex-wrap justify-center sm:justify-between items-center p-4">
        <div class="flex space-x-2 sm:space-x-6">
          <button id="btn-repertorio" class="nav-btn text-yellow-400 border-b-2 border-yellow-400 pb-1 font-semibold transition">Marchas</button>
          <button id="btn-instrumento" class="nav-btn text-slate-400 border-b-2 border-transparent hover:text-yellow-200 pb-1 font-semibold transition">Por Instrumento</button>
          <button id="btn-ranking" class="nav-btn text-slate-400 border-b-2 border-transparent hover:text-yellow-200 pb-1 font-semibold transition">Ranking 🏆</button>
        </div>
        <button id="btn-login" class="mt-4 sm:mt-0 px-5 py-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-200 font-bold uppercase tracking-wider text-xs rounded transition-colors">
          INICIAR SESIÓN
        </button>
      </div>
    </nav>
{/* BARRA DE LOGIN HORIZONTAL (SELECCIÓN SIMPLE) */}
    <div id="login-banner" class="hidden bg-slate-950 border-b border-yellow-600/30 w-full p-4 transition-all shadow-lg">
      <div class="max-w-4xl mx-auto flex flex-wrap items-end gap-4 sm:gap-6 justify-center sm:justify-start">
        
        {/* Botón X para cerrar */}
        <button id="btn-cerrar-banner" class="text-slate-500 hover:text-slate-300 mb-2 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

        {/* Selector de Nombre */}
        <div class="flex flex-col">
          <label class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-1">Selecciona tu Nombre</label>
          <div class="relative">
            <select id="select-nombre" class="h-9 rounded bg-slate-900 border border-slate-700 text-slate-200 px-3 pr-8 w-64 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition-all text-sm appearance-none cursor-pointer">
              <option value="">-- Buscar en lista --</option>
              {/* Las opciones se llenarán automáticamente con JavaScript */}
            </select>
            {/* Flechita para el selector */}
            <svg class="absolute right-3 top-2.5 w-4 h-4 text-slate-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
        </div>

        {/* Botón ENTRAR */}
        <button id="btn-guardar-login" class="h-9 px-6 bg-yellow-600 hover:bg-yellow-500 text-slate-950 font-bold tracking-widest uppercase text-sm rounded transition-colors mb-0 shadow-[0_0_10px_rgba(202,138,4,0.2)]">
          ENTRAR
        </button>
      </div>
    </div>
    <div id="vistas-container">
      
      <main id="vista-repertorio" class="vista-activa max-w-4xl mx-auto p-6 mt-8 block">
        <div class="flex justify-between items-end mb-8 border-b border-slate-700 pb-4">
          <h2 class="text-3xl text-slate-100" style="font-family: 'Playfair Display', serif;">Todas las marchas</h2>
          <p class="text-slate-400 text-sm">Banda completa · 11 marchas</p>
        </div>

        <div class="space-y-6">
{marchas.map((marcha) => (
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-yellow-600/50 transition-colors shadow-lg">
          <div class="flex items-center gap-4 mb-6">
            <span class="text-3xl font-bold text-yellow-600/50">{marcha.num}</span>
            <h3 class="text-xl font-semibold text-yellow-500">{marcha.nombre}</h3>
          </div>

          <div class="bg-slate-900 rounded-lg overflow-hidden border border-slate-700/50 aspect-video relative flex justify-center items-center">
            {marcha.videoId ? (
              <iframe src={`https://www.youtube.com/embed/${marcha.videoId}`} class="absolute top-0 left-0 w-full h-full" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            ) : (
              <p class="text-slate-500 text-sm flex items-center gap-2">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#64748b"><path d="M8 5.14v14l11-7-11-7z"></path></svg>
                Video no disponible
              </p>
            )}
          </div>

{/* Espacio para la orden escrita */}
          {marcha.orden && (
            <div class="mt-4 p-4 bg-slate-900/80 rounded-lg border-l-4 border-l-yellow-600 shadow-inner">
              <p class="text-slate-200 text-base leading-relaxed tracking-wide">
                <strong class="font-bold text-yellow-500 mr-2">ORDEN:</strong>
                {marcha.orden}
              </p>
            </div>
          )}
        </div>
      ))}
      </main>

      <main id="vista-instrumento" class="vista-oculta max-w-4xl mx-auto p-6 mt-4 hidden">

        <div class="flex space-x-6 border-b border-slate-700 mb-8 px-2">
          <button id="tab-pifano" class="text-yellow-400 border-b-2 border-yellow-400 pb-2 font-semibold text-sm uppercase tracking-wider flex items-center gap-2 transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 22 22 2"></path><circle cx="16" cy="8" r="1.5" fill="currentColor"></circle></svg>
            Pífano
          </button>
          <button id="tab-corneta" class="text-slate-400 border-b-2 border-transparent hover:text-yellow-200 pb-2 font-semibold text-sm uppercase tracking-wider flex items-center gap-2 transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m3 11 18-5v12L3 14v-3z"></path><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"></path></svg>
            Corneta
          </button>
          <button id="tab-caja" class="text-slate-400 border-b-2 border-transparent hover:text-yellow-200 pb-2 font-semibold text-sm uppercase tracking-wider flex items-center gap-2 transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 7c0-2.2 4.5-4 10-4s10 1.8 10 4-4.5 4-10 4-10-1.8-10-4z"></path></svg>
            Caja
          </button>
        </div>

        <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 mb-6 flex items-center gap-4 shadow-lg">
          <div class="w-14 h-14 rounded-full bg-slate-900 border border-yellow-600/30 flex items-center justify-center">
            <svg id="icono-instrumento-actual" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 22 22 2"></path><circle cx="16" cy="8" r="1.5" fill="#c9a84c"></circle><circle cx="12" cy="12" r="1.5" fill="#c9a84c"></circle><circle cx="8" cy="16" r="1.5" fill="#c9a84c"></circle>
            </svg>
          </div>
          <div>
            <h2 id="titulo-instrumento-actual" class="text-2xl font-bold text-slate-100" style="font-family: 'Playfair Display', serif;">Pífano</h2>
            <p id="desc-instrumento-actual" class="text-slate-400 text-sm">Flauta de pico de cuerpo cilíndrico</p>
          </div>
        </div>

        <p class="text-slate-500 text-xs uppercase tracking-widest mb-4">11 marchas disponibles · Toca para expandir</p>

        <div class="space-y-3">
          {marchas.map((marcha) => (
            <div class="acordeon-item bg-slate-800/50 border border-slate-700 rounded-lg overflow-hidden transition-all shadow-sm">
              <button class="acordeon-btn w-full px-6 py-4 flex items-center justify-between hover:bg-slate-700/50 transition">
                <div class="flex items-center gap-4">
                  <span class="text-xl font-bold text-yellow-600/80">{marcha.num}</span>
                  <span class="titulo-marcha-acordeon font-semibold text-slate-200">{marcha.nombre}</span>
                </div>
                <svg class="acordeon-icono w-5 h-5 text-slate-500 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </button>
              
             <div class="acordeon-contenido hidden px-4 py-6 bg-slate-900 border-t border-slate-700">
                <div class="bg-slate-950 border border-slate-700 rounded-xl shadow-inner max-w-2xl mx-auto overflow-hidden">
                  
                  {marcha.midiPifano ? (
                    <div>
                      
                      {/* 1. ZONA DE IMÁGENES (SOLO PÍFANO) */}
                      <div class="contenedor-digitacion bg-slate-900 p-6 flex flex-col items-center justify-center border-b border-slate-700">
                        <p class="text-slate-500 text-xs uppercase tracking-widest mb-4 font-bold">Digitación del Pífano</p>
                        <div class="w-full h-100 flex items-center justify-center p-2">
                          <img 
                            id={`img-digitacion-${marcha.num}`}
                            src="/img/digitacion/pifano/silencio.png" 
                            alt="Digitación Pífano"
                            class="max-w-full max-h-full object-contain transition-opacity duration-100 opacity-40"
                          />
                        </div>
                      </div>

                      {/* 2. ZONA DEL REPRODUCTOR Y BOTONES (PÍFANO Y CAJA) */}
                      <div class="seccion-midi">
                        <midi-player 
                          id={`player-${marcha.num}`} 
                          data-pifano={marcha.midiPifano}
                          data-corneta={marcha.midiCorneta}
                          data-caja={marcha.midiCaja}
                          src={marcha.midiPifano} 
                          sound-font="https://storage.googleapis.com/magentadata/js/soundfonts/sgm_plus"
                          style="visibility: hidden; height: 0; width: 0; position: absolute;"
                        ></midi-player>

                        <div class="p-5 flex items-center justify-between bg-slate-950">
                          <div class="flex bg-slate-800 rounded-lg p-1 controles-velocidad">
                            <button class="btn-vel px-3 py-1 text-xs font-bold text-slate-400" data-vel="0.5">50%</button>
                            <button class="btn-vel px-3 py-1 text-xs font-bold text-slate-400" data-vel="0.75">75%</button>
                            <button class="btn-vel px-3 py-1 text-xs font-bold bg-slate-700 text-yellow-400 activo" data-vel="1">100%</button>
                          </div>
                          
                          <button class="btn-play w-14 h-14 bg-yellow-600 rounded-full flex items-center justify-center" data-target={`player-${marcha.num}`}>
                            <svg class="icon-play" width="24" height="24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
                            <svg class="icon-pause hidden" width="24" height="24" fill="currentColor"><path d="M6 4h4v16H6zM14 4h4v16h-4z"></path></svg>
                          </button>
                        </div>
                      </div>

                      {/* 3. ZONA DE VIDEO YOUTUBE (SOLO CORNETA) */}
                      <div class="seccion-video-corneta hidden w-full">
                        <div class="bg-slate-900 rounded-lg overflow-hidden border border-slate-700/50 aspect-video relative flex justify-center items-center">
                          {marcha.videoCorneta ? (
                            <iframe src={`https://www.youtube.com/embed/${marcha.videoCorneta}`} class="absolute top-0 left-0 w-full h-full" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                          ) : (
                            <p class="text-slate-500 text-sm flex items-center gap-2">
                              <svg width="20" height="20" viewBox="0 0 24 24" fill="#64748b"><path d="M8 5.14v14l11-7-11-7z"></path></svg>
                              Video no disponible
                            </p>
                          )}
                        </div>
                      </div>

                    </div>
                  ) : (
                    <div class="h-32 flex flex-col items-center justify-center gap-2">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2"><path d="M12 2v20"></path><path d="m15 22-6-15"></path><path d="m9 22 6-15"></path><circle cx="12" cy="22" r="2"></circle></svg>
                      <p class="text-slate-500 text-sm font-mono tracking-wide">Audio MIDI en preparación...</p>
                    </div>
                  )}

                </div>
              </div>
			</div>
		  ))}
        </div>

      </main>

    {/* VISTA DEL RANKING */}
    <main id="vista-ranking" class="hidden px-4 py-8 w-full max-w-4xl mx-auto transition-all">
      <div class="text-center mb-8">
        <h2 class="text-3xl text-slate-100 font-bold tracking-widest uppercase mb-1" style="font-family: 'Playfair Display', serif;">
          Ranking Global 🏆
        </h2>
        <p class="text-slate-400 text-xs uppercase tracking-widest">
          Los alumnos más comprometidos de la banda
        </p>
      </div>

      {/* ESTE ES EL CONTENEDOR CLAVE DONDE FIREBASE INYECTARÁ LA TABLA */}
      <div id="tabla-ranking-contenedor" class="w-full max-w-lg mx-auto">
        <div class="flex justify-center items-center py-10">
          <span class="text-yellow-600 font-bold uppercase tracking-widest text-sm animate-pulse">
            Conectando con la base de datos...
          </span>
        </div>
      </div>
      {/* EXPLICACIÓN DEL RANKING CON PREMIO */}
      <div class="mt-8 bg-slate-800/30 border border-slate-700/50 rounded-lg p-5 text-center max-w-md mx-auto shadow-sm">
        <h3 class="text-yellow-500 font-bold text-xs tracking-widest uppercase mb-2">
          Mecánica del Ranking
        </h3>
        <p class="text-sm text-slate-300 leading-relaxed mb-2">
          La disciplina tiene su recompensa. Cada vez que inicies sesión para ensayar tu instrumento, sumas <strong class="text-white">15 puntos</strong>.
        </p>
        <p class="text-xs text-slate-400 mb-4">
          Para mantener una competencia justa, hay un límite de <strong class="text-slate-200">3 registros diarios</strong> (máx. 45 puntos por día). El contador se reinicia cada medianoche.
        </p>
        <p class="text-xs text-slate-400 mb-4">
          Solo se puede iniciar sesión cada <strong class="text-slate-200">20 minutos</strong> 
        </p>
        <div class="bg-slate-900/60 border border-yellow-600/30 rounded py-2 px-4 inline-block">
          <p class="text-xs text-yellow-500 font-medium tracking-wide">
            🏆 Habrá premios a fin de año para los primeros 3 puestos 🏆<br class="hidden sm:block" /> Cortesía del profe Pablo
          </p>
        </div>
      </div>
    </main>

    </div>

    <footer class="bg-slate-950 border-t border-yellow-600/20 py-8 mt-12 text-center">
      <p class="text-xs text-slate-500 tracking-widest uppercase">
        Banda Escolar · Liceo San José del Carmen · Material de Ensayo
      </p>
    </footer>

<script>
  // === IMPORTACIONES DE FIREBASE (NUBE) ===
  import { initializeApp } from "firebase/app";
  import { getFirestore, doc, getDoc, setDoc, onSnapshot, collection, query, orderBy } from "firebase/firestore";

  const firebaseConfig = {
    apiKey: "AIzaSyBssDf2A_QSsS3bgdLaTbhvZRStRfBqEY",
    authDomain: "banda-huique.firebaseapp.com",
    projectId: "banda-huique",
    storageBucket: "banda-huique.firebasestorage.app",
    messagingSenderId: "910285903656",
    appId: "1:910285903656:web:28bbf2e19728a1c6da621d",
    measurementId: "G-17HHECV818"
  };

  const app = initializeApp(firebaseConfig);
  const db = getFirestore(app);

  // === SECCIONES INTACTAS (1 A 4) ===

  // 1. NAVEGACIÓN Y ACORDEONES
  document.querySelectorAll('.nav-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const vista = e.target.id.replace('btn-', 'vista-');
      document.querySelectorAll('main').forEach(m => m.classList.add('hidden'));
      document.getElementById(vista).classList.remove('hidden');

      document.querySelectorAll('.nav-btn').forEach(b => {
        b.classList.remove('text-yellow-400', 'border-yellow-400');
        b.classList.add('text-slate-400', 'border-transparent');
      });
      e.target.classList.add('text-yellow-400', 'border-yellow-400');
      e.target.classList.remove('text-slate-400', 'border-transparent');
    });
  });

  document.querySelectorAll('.acordeon-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const contenido = btn.nextElementSibling;
      const estabaOculto = contenido.classList.contains('hidden');
      document.querySelectorAll('.acordeon-contenido').forEach(c => c.classList.add('hidden'));
      if (estabaOculto) {
        contenido.classList.remove('hidden');
      }
    });
  });

  // 2. REPRODUCTOR Y VELOCIDAD
  document.querySelectorAll('.btn-play').forEach(btn => {
    btn.addEventListener('click', async function() {
      const player = document.getElementById(this.getAttribute('data-target'));
      if (typeof Tone !== 'undefined') await Tone.context.resume();

      if (player.playing) {
        player.stop();
        this.classList.remove('text-yellow-400', 'border-yellow-400', 'bg-slate-800');
        this.classList.add('text-slate-300', 'border-transparent');
      } else {
        await player.start();
        this.classList.remove('text-slate-300', 'border-transparent');
        this.classList.add('text-yellow-400', 'border-yellow-400', 'bg-slate-800');
      }
    });
  });

  document.querySelectorAll('.btn-vel').forEach(btn => {
    btn.addEventListener('click', function() {
      const grupo = this.parentElement;
      grupo.querySelectorAll('.btn-vel').forEach(b => {
        b.classList.remove('text-yellow-400', 'border-yellow-400', 'font-bold');
        b.classList.add('text-slate-400', 'border-transparent');
      });
      this.classList.remove('text-slate-400', 'border-transparent');
      this.classList.add('text-yellow-400', 'border-yellow-400', 'font-bold');

      const multi = parseFloat(this.getAttribute('data-vel'));
      const player = this.closest('.acordeon-contenido').querySelector('midi-player');
      
      if (!player.dataset.originalNs) player.dataset.originalNs = JSON.stringify(player.noteSequence);
      const copia = JSON.parse(player.dataset.originalNs);
      const factor = 1 / multi;
      
      copia.notes.forEach(n => { n.startTime *= factor; n.endTime *= factor; });
      copia.totalTime *= factor;
      
      const estabaSonando = player.playing;
      if (estabaSonando) player.stop();
      player.noteSequence = copia;
      if (estabaSonando) setTimeout(() => player.start(), 100);
    });
  });

  // 3. DIGITACIÓN VISUAL (MEMORIA PERSISTENTE)
  const mapa = { 74: "d5", 76: "e5", 78: "fs5", 79: "g5", 81: "a5", 83: "b5", 85: "cs6", 86: "d6" };
  let estadoActual = {};

  setInterval(() => {
    document.querySelectorAll('midi-player').forEach(player => {
      const idMarcha = player.id.split('-')[1];
      const img = document.getElementById(`img-digitacion-${idMarcha}`);
      if (!img) return;

      if (!player.playing) {
        if (estadoActual[idMarcha] !== 'silencio') {
          img.src = "/img/digitacion/pifano/silencio.png";
          img.style.opacity = "0.4";
          estadoActual[idMarcha] = 'silencio';
        }
        return;
      }

      const nota = player.noteSequence.notes.find(n => 
        player.currentTime >= n.startTime && player.currentTime <= n.endTime
      );
      
      if (nota && mapa[nota.pitch] && estadoActual[idMarcha] !== mapa[nota.pitch]) {
        img.src = `/img/digitacion/pifano/${mapa[nota.pitch]}.png`;
        img.style.opacity = "1";
        estadoActual[idMarcha] = mapa[nota.pitch];
      }
    });
  }, 50); 

  // 4. CAMBIO DE INSTRUMENTO (Pífano, Corneta, Caja)
  document.querySelectorAll('[id^="tab-"]').forEach(tab => {
    tab.addEventListener('click', (e) => {
      const instrumento = e.currentTarget.id.replace('tab-', '');

      document.querySelectorAll('[id^="tab-"]').forEach(t => {
        t.classList.remove('text-yellow-400', 'border-yellow-400');
        t.classList.add('text-slate-400', 'border-transparent');
      });
      e.currentTarget.classList.add('text-yellow-400', 'border-yellow-400');
      e.currentTarget.classList.remove('text-slate-400', 'border-transparent');

      const titulos = {
        'pifano': { nombre: 'Pífano', desc: 'Flauta de pico de cuerpo cilíndrico' },
        'corneta': { nombre: 'Corneta', desc: 'Instrumento de viento metal' },
        'caja': { nombre: 'Caja', desc: 'Instrumento de percusión' }
      };
      document.getElementById('titulo-instrumento-actual').innerText = titulos[instrumento].nombre;
      document.getElementById('desc-instrumento-actual').innerText = titulos[instrumento].desc;

      document.querySelectorAll('.contenedor-digitacion').forEach(div => {
        if (instrumento === 'pifano') {
          div.classList.remove('hidden');
        } else {
          div.classList.add('hidden');
        }
      });

      document.querySelectorAll('.acordeon-contenido').forEach(contenido => {
        const seccionMidi = contenido.querySelector('.seccion-midi');
        const seccionVideo = contenido.querySelector('.seccion-video-corneta');
        
        if (instrumento === 'corneta') {
          if (seccionMidi) seccionMidi.classList.add('hidden');
          if (seccionVideo) seccionVideo.classList.remove('hidden');
        } else {
          if (seccionMidi) seccionMidi.classList.remove('hidden');
          if (seccionVideo) seccionVideo.classList.add('hidden');
        }
      });

      document.querySelectorAll('.acordeon-contenido').forEach(c => c.classList.add('hidden'));

      document.querySelectorAll('midi-player').forEach(player => {
        if (player.playing) player.stop();
        
        if (instrumento !== 'corneta') {
          const nuevaRuta = player.getAttribute(`data-${instrumento}`);
          if (nuevaRuta && nuevaRuta !== "null") {
            player.src = nuevaRuta;
            delete player.dataset.originalNs; 
          }
        }
      });
    });
  });

  // === SECCIÓN 7 y 8: LÓGICA DE FIREBASE Y RANKING REAL ===
  
  // 7. SISTEMA DE LOGIN Y CHECK-IN EN LA NUBE
  const alumnosPorCurso = {
    "4° Básico": [
      "Juanito Pérez", "José Pepito", "Nicolaso Gómez", "Cristóbal Pino", "Elena Barrera", "Isidora Martinez", "Julián Ávila", 
      "Marcelo Farías", "Noelia Pérez", "Omar Yáñez", "Pablo Lizana", 
      "Rocío Pino", "Theo Valdés", "Yeremi Olivares"
    ],
    "5° Básico": [
      "Agustina Palomino", "Alexia Cáceres", "Florencia Pino", "Isabella Gallegos", 
      "León Arriagada", "Paolo Millacaris", "Patricio Pérez"
    ],
    "6° Básico": [
      "Diana Martínez", "Ian Vargas", "Javier Palacios", "Julio Tobar", 
      "Matías González", "Nahin Pino", "Renata Alarcón"
    ],
    "7° Básico": [
      "Alonso Palacios", "Ángel Jofré", "Emily González", "Javier Pino", 
      "Maite Rojas", "Martin Cabello", "Paolo Ibarra", "Santiago Rubio", "Vincent Zapata"
    ],
    "8° Básico": [
      "Dennise Ávila", "Joaquín Horta", "Pedro Pablo Calderón"
    ],
    "1° MA": [
      "Alejandro Oteíza", "Carlos Barrios", "Nicol Nuñez", "Sofia Duarte"
    ],
    "1° MB": [
      "Genesis Calderón", "Matias Chavez"
    ],
    "2° MA": [
      "Alejandra Pérez", "Amarilis Leiva", "Aylin Fernández", "Camila Barrios", 
      "Cristóbal Carrasco", "Cristofer Aguilera", "Francheska Lizana", 
      "Krishna Saavedra", "Millaray Serrano", "Pía Pérez", "Valentina Chaparro"
    ],
    "2° MB": [
      "Alexis Guerrero", "Álvaro Millacaris"
    ],
    "3° MA": [
      "Joaquín Contreras", "Jonathan Núñez", "Maite Valdés", "Sebastián Gómez"
    ],
    "3° MB": [
      "Genaro Pérez", "Jesús Gallegos", "José Romero"
    ],
    "3° MC": [
      "David Molina", "Pedro Farias", "Valeria Campos"
    ]
  };

  const btnLogin = document.getElementById('btn-login');
  const loginBanner = document.getElementById('login-banner');
  const btnCerrarBanner = document.getElementById('btn-cerrar-banner');
  const btnGuardarLogin = document.getElementById('btn-guardar-login');
  const selectNombre = document.getElementById('select-nombre');

  // Llenar el selector
  for (const curso in alumnosPorCurso) {
    const grupo = document.createElement('optgroup');
    grupo.label = curso; 
    const alumnos = alumnosPorCurso[curso].sort();
    alumnos.forEach(nombre => {
      const option = document.createElement('option');
      option.value = nombre;
      option.textContent = nombre;
      grupo.appendChild(option);
    });
    selectNombre.appendChild(grupo);
  }

// Función para actualizar el botón de arriba
  function actualizarUI() {
    const nombre = localStorage.getItem('alumnoBanda');
    if (nombre) {
      btnLogin.innerHTML = `<span class="uppercase tracking-widest text-xs font-bold text-yellow-500">${nombre}</span>`;
      btnLogin.className = "mt-4 sm:mt-0 px-4 py-2 bg-slate-900 border border-slate-700 hover:border-yellow-600/50 rounded transition-colors flex items-center cursor-pointer shadow-sm";
    } else {
      // AQUÍ ESTÁ EL CAMBIO DE TEXTO
      btnLogin.innerHTML = 'REGISTRA TU PRÁCTICA';
      btnLogin.className = "mt-4 sm:mt-0 px-5 py-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-200 font-bold uppercase tracking-wider text-xs rounded transition-colors cursor-pointer";
    }
  }

  actualizarUI();

  btnLogin.addEventListener('click', () => {
    if (localStorage.getItem('alumnoBanda')) {
      if(confirm('¿Quieres cerrar tu sesión de ensayo en este dispositivo?')) {
        localStorage.removeItem('alumnoBanda');
        actualizarUI();
      }
    } else {
      loginBanner.classList.toggle('hidden');
    }
  });

  btnCerrarBanner.addEventListener('click', () => {
    loginBanner.classList.add('hidden');
    selectNombre.value = ''; 
  });

  // Guardar en la NUBE (Firebase) con restricción de tiempo
  btnGuardarLogin.addEventListener('click', async () => {
    const nombre = selectNombre.value;
    
    if (nombre) {
      const textoOriginal = btnGuardarLogin.innerHTML;
      btnGuardarLogin.innerHTML = "CARGANDO...";
      btnGuardarLogin.disabled = true;

      try {
        const alumnoRef = doc(db, "ranking", nombre);
        const docSnap = await getDoc(alumnoRef);
        
        const ahora = new Date();
        const hoy = ahora.toDateString();
        
        let perfil = { 
          puntos: 0, 
          ultimaFecha: "", 
          iniciosHoy: 0, 
          nombre: nombre, 
          ultimoCheckIn: 0 // Nueva variable para controlar los 20 min
        };

        if (docSnap.exists()) {
          perfil = docSnap.data();
        }

        // Reiniciar si es día nuevo
        if (perfil.ultimaFecha !== hoy) {
          perfil.ultimaFecha = hoy;
          perfil.iniciosHoy = 0;
        }

        // Lógica de 20 minutos
        const tiempoTranscurrido = (ahora.getTime() - perfil.ultimoCheckIn) / 1000 / 60; // en minutos

        if (perfil.iniciosHoy < 3) {
          if (perfil.ultimoCheckIn === 0 || tiempoTranscurrido >= 20) {
            perfil.iniciosHoy++;
            perfil.puntos += 15;
            perfil.ultimoCheckIn = ahora.getTime(); // Guardamos el tiempo actual
            
            await setDoc(alumnoRef, perfil);
            alert(`¡Check-in exitoso, ${nombre}!\n\nLlevas ${perfil.iniciosHoy}/3 sesiones hoy.\nHas sumado 15 puntos.\n\n(Recuerda: tu próxima sesión puntuable será en 20 minutos).`);
          } else {
            const minutosFaltantes = Math.ceil(20 - tiempoTranscurrido);
            alert(`¡Calma, ${nombre}!\n\nDebes esperar al menos 20 minutos entre sesiones para sumar puntos.\n\nTe faltan ${minutosFaltantes} minutos para el siguiente check-in.`);
          }
        } else {
          alert(`¡Ya alcanzaste el límite de 3/3 sesiones hoy!\nNos vemos mañana para seguir sumando.`);
        }

        localStorage.setItem('alumnoBanda', nombre); 
        loginBanner.classList.add('hidden'); 
        selectNombre.value = '';
        actualizarUI(); 

      } catch (error) {
        console.error("Error al guardar:", error);
        alert("Error de conexión. Inténtalo de nuevo.");
      } finally {
        btnGuardarLogin.innerHTML = textoOriginal;
        btnGuardarLogin.disabled = false;
      }
      
    } else {
      selectNombre.classList.add('ring-2', 'ring-red-500');
      setTimeout(() => selectNombre.classList.remove('ring-2', 'ring-red-500'), 1500);
    }
  });

  // 8. ESCUCHADOR EN TIEMPO REAL PARA EL RANKING
  const contenedorRanking = document.getElementById('tabla-ranking-contenedor');
  
  if (contenedorRanking) {
    const q = query(collection(db, "ranking"), orderBy("puntos", "desc"));
    
    onSnapshot(q, (querySnapshot) => {
      if (querySnapshot.empty) {
        contenedorRanking.innerHTML = `
          <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-8 text-center text-slate-500 text-sm">
            Aún no hay registros de ensayo. ¡Sé el primero en sumar puntos!
          </div>`;
        return;
      }

      let html = `<div class="bg-slate-900 border border-slate-800 rounded-md overflow-hidden shadow-2xl">`;
      let index = 0;
      
      querySnapshot.forEach((doc) => {
        // Dentro del bucle querySnapshot.forEach((doc) => { ...
const alumno = doc.data();

// Estilos para el podio (Top 3)
const esTop = index < 3;
const fondoFila = esTop ? "bg-slate-800/50 border-yellow-500/20" : "border-b border-slate-800/60";
const brilloTexto = esTop ? "text-transparent bg-clip-text bg-gradient-to-r from-yellow-200 to-yellow-600 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)] font-bold" : "text-slate-200";

let posicion = "";
if (index === 0) posicion = "🥇";
else if (index === 1) posicion = "🥈";
else if (index === 2) posicion = "🥉";
else posicion = `<span class="text-slate-600 font-mono text-xs w-5 inline-block">${index + 1}.</span>`;

html += `
  <div class="flex justify-between items-center p-4 ${fondoFila} transition-all duration-300">
    <div class="flex items-center gap-3">
      <div class="w-6 text-center">${posicion}</div>
      <span class="text-sm ${brilloTexto}">${alumno.nombre}</span>
    </div>
    <span class="text-sm font-black text-yellow-500 font-mono drop-shadow-[0_0_5px_rgba(234,179,8,0.3)]">${alumno.puntos} PTS</span>
  </div>
`;
        index++;
      });

      html += `</div>`;
      contenedorRanking.innerHTML = html;
    });
  }
  const capaBloqueo = document.getElementById('login-password');
  const inputPass = document.getElementById('input-password');
  const btnAcceder = document.getElementById('btn-acceder');

  btnAcceder.addEventListener('click', () => {
    if (inputPass.value === 'bandaliceo2026') {
      capaBloqueo.style.opacity = '0';
      setTimeout(() => capaBloqueo.classList.add('hidden'), 500);
      localStorage.setItem('accesoConcedido', 'true');
    } else {
      inputPass.classList.add('ring-2', 'ring-red-500');
      setTimeout(() => inputPass.classList.remove('ring-2', 'ring-red-500'), 500);
    }
  });

  // Verificar si ya ingresó antes
  if (localStorage.getItem('accesoConcedido') === 'true') {
    capaBloqueo.classList.add('hidden');
  }
</script>

